# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: mock | openai | groq | huggingface
LLM_PROVIDER=openai
LLM_API_KEY=sk-...

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, works out of the box)
DATABASE_URL=sqlite:///./support_platform.db
# PostgreSQL (optional, for production scale)
# DATABASE_URL=postgresql://user:password@localhost:5432/support_db

# ── Vector Store ──────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIRECTORY=./chroma_db

# ── Auth ──────────────────────────────────────────────────────────────────────
# Change this to a long random string in production
JWT_SECRET=change-me-in-production

# ── Telegram Bot (optional) ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
