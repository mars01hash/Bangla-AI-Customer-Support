# Security
JWT_SECRET=supersecretjwtsecretkeychangeinproduction123456789
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ADMIN_INITIAL_PASSWORD=adminpassword123

# Database Settings
# For Docker / Production, uncomment the PostgreSQL URL
# DATABASE_URL=postgresql://postgres:postgres@db:5432/support_db
DATABASE_URL=sqlite:///./support_platform.db

# Vector Database (ChromaDB)
CHROMA_PERSIST_DIRECTORY=./chroma_db

# LLM Agent Configuration
# Supported providers: "mock", "openai", "groq", "huggingface"
LLM_PROVIDER=mock
LLM_API_KEY=mock-key-for-local-testing
LLM_MODEL_NAME=qwen-3-7b-chat

# Embedding Model Name
# Default is a highly capable multilingual sentence transformer
EMBEDDING_MODEL_NAME=sentence-transformers/LaBSE

# API Service Config
HOST=0.0.0.0
PORT=8090
DEBUG=True
