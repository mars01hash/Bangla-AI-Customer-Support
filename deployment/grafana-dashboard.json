{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "Bangla AI Customer Support",
  "uid": "bangla-support",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total Chat Messages",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } } },
      "targets": [{ "expr": "sum(chat_requests_total)", "legendFormat": "Messages" }]
    },
    {
      "id": 2,
      "title": "Total Tickets Created",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "orange", "value": null }] } } },
      "targets": [{ "expr": "sum(tickets_created_total)", "legendFormat": "Tickets" }]
    },
    {
      "id": 3,
      "title": "Total Orders Placed",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } },
      "targets": [{ "expr": "sum(orders_placed_total)", "legendFormat": "Orders" }]
    },
    {
      "id": 4,
      "title": "Active Conversations",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "purple", "value": null }] } } },
      "targets": [{ "expr": "active_conversations_total", "legendFormat": "Conversations" }]
    },
    {
      "id": 5,
      "title": "Chat Request Rate (per min)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "targets": [
        { "expr": "sum(rate(chat_requests_total[2m])) * 60", "legendFormat": "All" },
        { "expr": "sum(rate(chat_requests_total{language=\"bn\"}[2m])) * 60", "legendFormat": "Bangla" },
        { "expr": "sum(rate(chat_requests_total{language=\"en\"}[2m])) * 60", "legendFormat": "English" }
      ]
    },
    {
      "id": 6,
      "title": "Chat Response Time (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(chat_latency_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(chat_latency_seconds_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(chat_latency_seconds_bucket[5m]))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 7,
      "title": "Messages by Sentiment",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "pieType": "donut", "displayLabels": ["name", "percent"] },
      "targets": [
        { "expr": "sum by(sentiment) (chat_requests_total)", "legendFormat": "{{sentiment}}" }
      ]
    },
    {
      "id": 8,
      "title": "Messages by Language",
      "type": "piechart",
      "gridPos": { "x": 8, "y": 12, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "pieType": "donut", "displayLabels": ["name", "percent"] },
      "targets": [
        { "expr": "sum by(language) (chat_requests_total)", "legendFormat": "{{language}}" }
      ]
    },
    {
      "id": 9,
      "title": "Backend Memory Usage",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 12, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "targets": [
        { "expr": "process_resident_memory_bytes", "legendFormat": "RSS Memory" }
      ]
    }
  ]
}
